# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

DATABASE_URL=""

# JWT
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Google OAuth
GOOGLE_IOS_CLIENT_ID=""

# Google Calendar (separate OAuth client - web type for authorization code flow)
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI=""
GOOGLE_CALENDAR_WEBHOOK_BASE_URL=""
MOBILE_DEEP_LINK_CALENDAR_SUCCESS=""
MOBILE_DEEP_LINK_CALENDAR_FAILURE=""

# AES-256-GCM key (base64 of 32 random bytes). Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Redis (BullMQ backend + OAuth state)
REDIS_URL=""

# JWT Upload (presigned URL 무결성 검증용 — canvas/OCR versionToken, ocrToken)
JWT_UPLOAD_SECRET=""

# Cloudflare R2 (canvas PencilKit 데이터 + OCR 이미지 저장)
# endpoint 형식: https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=""
R2_ENDPOINT=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""

# Google Cloud Vision API (OCR)
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → API 키 만들기
# Cloud Vision API 활성화 필요: console.cloud.google.com → API 라이브러리 → Cloud Vision API
GOOGLE_VISION_API_KEY=""

# APNs (Apple Push Notifications)
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=FGHIJ67890
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.example.fanesis
APNS_PRODUCTION=false
REMINDER_LEAD_MINUTES=1

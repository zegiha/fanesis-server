generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Users {
  uuid                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String?
  displayName          String?                @map("display_name")
  language             Language
  timezone             String
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?              @map("deleted_at") @db.Timestamptz(6)
  oauthIdentities      OAuthIdentities[]
  folders              Folders[]
  tasks                Tasks[]
  calendarIntegrations CalendarIntegrations[]
  devices              Devices[]
  canvases             Canvases[]

  @@map("users")
}

model Folders {
  uuid      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid  String          @map("user_uuid") @db.Uuid
  name      String
  color     AccentColorKey
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      Users           @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  tasks     Tasks[]

  @@index([userUuid], map: "idx_folders_user")
  @@map("folders")
}

model Tasks {
  uuid            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid        String              @map("user_uuid") @db.Uuid
  title           String
  priority        TaskPriority?
  affiliation     TaskAffiliation?
  backlogKind     TaskBacklogKind     @map("backlog_kind")
  backlogFolderId String?             @map("backlog_folder_id") @db.Uuid
  activeKind      TaskActiveKind?     @map("active_kind")
  timeboxKind     TaskTimeboxKind?    @map("timebox_kind")
  scheduledDate   DateTime?           @map("scheduled_date") @db.Date
  startTime       DateTime?           @map("start_time") @db.Time(6)
  durationSec     Int?                @map("duration_sec")
  chunkSec        Int?                @map("chunk_sec")
  breakSec        Int?                @map("break_sec")
  doneDate        DateTime?           @map("done_date") @db.Timestamptz(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            Users               @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  backlogFolder   Folders?            @relation(fields: [backlogFolderId], references: [uuid], onDelete: SetNull)
  externalLink    TaskExternalLinks?
  canvasSource    TaskCanvasSources?

  @@index([userUuid], map: "idx_tasks_user")
  @@map("tasks")
}

model CalendarIntegrations {
  uuid                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid               String                   @map("user_uuid") @db.Uuid
  provider               CalendarProvider
  providerAccountId      String                   @map("provider_account_id")
  providerEmail          String                   @map("provider_email")
  accessTokenEncrypted   String                   @map("access_token_encrypted")
  refreshTokenEncrypted  String                   @map("refresh_token_encrypted")
  tokenExpiresAt         DateTime                 @map("token_expires_at") @db.Timestamptz(6)
  isActive               Boolean                  @default(true) @map("is_active")
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                   Users                    @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  syncedCalendars        CalendarSyncedCalendars[]

  @@unique([userUuid, provider, providerAccountId])
  @@index([userUuid], map: "idx_calendar_integrations_user")
  @@map("calendar_integrations")
}

model CalendarSyncedCalendars {
  uuid                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationUuid     String               @map("integration_uuid") @db.Uuid
  externalCalendarId  String               @map("external_calendar_id")
  summary             String?
  syncToken           String?              @map("sync_token")
  lastSyncedAt        DateTime?            @map("last_synced_at") @db.Timestamptz(6)
  webhookChannelId    String?              @unique @map("webhook_channel_id")
  webhookResourceId   String?              @map("webhook_resource_id")
  webhookExpiresAt    DateTime?            @map("webhook_expires_at") @db.Timestamptz(6)
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  integration         CalendarIntegrations @relation(fields: [integrationUuid], references: [uuid], onDelete: Cascade)
  taskLinks           TaskExternalLinks[]

  @@unique([integrationUuid, externalCalendarId])
  @@index([integrationUuid], map: "idx_synced_calendars_integration")
  @@map("calendar_synced_calendars")
}

model TaskExternalLinks {
  taskUuid           String                  @id @map("task_uuid") @db.Uuid
  syncedCalendarUuid String                  @map("synced_calendar_uuid") @db.Uuid
  externalEventId    String                  @map("external_event_id")
  externalEtag       String?                 @map("external_etag")
  lastSyncedAt       DateTime                @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  task               Tasks                   @relation(fields: [taskUuid], references: [uuid], onDelete: Cascade)
  syncedCalendar     CalendarSyncedCalendars @relation(fields: [syncedCalendarUuid], references: [uuid], onDelete: Cascade)

  @@unique([syncedCalendarUuid, externalEventId])
  @@index([syncedCalendarUuid], map: "idx_task_external_links_calendar")
  @@map("task_external_links")
}

model Devices {
  uuid         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid     String   @map("user_uuid") @db.Uuid
  pushToken    String   @unique @map("push_token")
  deviceName   String?  @map("device_name")
  deviceModel  String?  @map("device_model")
  appVersion   String?  @map("app_version")
  osVersion    String?  @map("os_version")
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         Users    @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid], map: "idx_devices_user")
  @@map("devices")
}

enum CalendarProvider {
  google
}

model OAuthIdentities {
  uuid           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid       String        @map("user_uuid") @db.Uuid
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt     DateTime      @default(now()) @map("last_used_at") @db.Timestamptz(6)
  user           Users         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userUuid, provider])
  @@index([userUuid], map: "idx_oauth_user")
  @@map("oauth_identities")
}

enum Language {
  ko
  en
}

enum OAuthProvider {
  google
  apple
}

enum AccentColorKey {
  red
  orange
  yellow
  green
  blue
  violet
  gray
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskBacklogKind {
  inbox
  folder
}

enum TaskActiveKind {
  todo
  big3
}

enum TaskTimeboxKind {
  timeline
}

enum TaskAffiliation {
  google
}

model Canvases {
  uuid             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid         String              @map("user_uuid") @db.Uuid
  date             DateTime            @db.Date
  storageKey       String              @map("storage_key")
  version          String              @default("v1.init")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             Users               @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  taskCanvasSources TaskCanvasSources[]

  @@unique([userUuid, date])
  @@map("canvases")
}

model TaskCanvasSources {
  taskUuid   String    @id @map("task_uuid") @db.Uuid
  canvasUuid String?   @map("canvas_uuid") @db.Uuid
  sourceKey  String    @unique @map("source_key")
  ocrText    String?   @map("ocr_text")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  task       Tasks     @relation(fields: [taskUuid], references: [uuid], onDelete: Cascade)
  canvas     Canvases? @relation(fields: [canvasUuid], references: [uuid], onDelete: SetNull)

  @@map("task_canvas_sources")
}

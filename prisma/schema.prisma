// CREATE UNIQUE INDEX idx_users_email_active ON users(lower(email)) 
// WHERE email IS NOT NULL AND deleted_at IS NULL;

enum OAuthProvider {
  google
  apple
}

model OAuthIdentities {
  uuid           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid       String        @map("user_uuid") @db.Uuid
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")
  createdAt      DateTime      @default(now()) @map("created_at")  @db.Timestamptz
  lastUsedAt     DateTime      @default(now()) @map("last_used_at") @db.Timestamptz


  user           Users         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userUuid, provider])
  @@index([userUuid], map: "idx_oauth_user")
  @@map("oauth_identities")
}


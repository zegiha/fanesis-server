generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Users {
  uuid                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String?
  displayName          String?                @map("display_name")
  language             Language
  timezone             String
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?              @map("deleted_at") @db.Timestamptz(6)
  oauthIdentities      OAuthIdentities[]
  folders              Folders[]
  tasks                Tasks[]
  routines             Routines[]
  calendarIntegrations CalendarIntegrations[]
  devices              Devices[]
  canvases             Canvases[]
  termsAgreements      TermsAgreements[]
  focusSessions        FocusSessions[]
  subscriptions        Subscriptions[]
  subscriptionEvents   SubscriptionEvents[]

  @@map("users")
}

model Folders {
  uuid      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid  String         @map("user_uuid") @db.Uuid
  name      String
  color     AccentColorKey
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      Users          @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  tasks     Tasks[]

  @@index([userUuid], map: "idx_folders_user")
  @@map("folders")
}

model Tasks {
  uuid            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid        String             @map("user_uuid") @db.Uuid
  title           String
  priority        TaskPriority?
  affiliation     TaskAffiliation?
  backlogKind     TaskBacklogKind    @map("backlog_kind")
  backlogFolderId String?            @map("backlog_folder_id") @db.Uuid
  activeKind      TaskActiveKind?    @map("active_kind")
  timeboxKind     TaskTimeboxKind?   @map("timebox_kind")
  scheduledDate   DateTime?          @map("scheduled_date") @db.Date
  startTime       DateTime?          @map("start_time") @db.Time(6)
  durationSec     Int?               @map("duration_sec")
  chunkSec        Int?               @map("chunk_sec")
  breakSec        Int?               @map("break_sec")
  doneDate        DateTime?          @map("done_date") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            Users              @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  backlogFolder   Folders?           @relation(fields: [backlogFolderId], references: [uuid], onDelete: SetNull)
  externalLink    TaskExternalLinks?
  canvasSource    TaskCanvasSources?
  focusSessions   FocusSessions[]

  @@index([userUuid], map: "idx_tasks_user")
  @@map("tasks")
}

model CalendarIntegrations {
  uuid                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid              String                    @map("user_uuid") @db.Uuid
  provider              CalendarProvider
  providerAccountId     String                    @map("provider_account_id")
  providerEmail         String                    @map("provider_email")
  accessTokenEncrypted  String                    @map("access_token_encrypted")
  refreshTokenEncrypted String                    @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime                  @map("token_expires_at") @db.Timestamptz(6)
  isActive              Boolean                   @default(true) @map("is_active")
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  Users                     @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  syncedCalendars       CalendarSyncedCalendars[]

  @@unique([userUuid, provider, providerAccountId])
  @@index([userUuid], map: "idx_calendar_integrations_user")
  @@map("calendar_integrations")
}

model CalendarSyncedCalendars {
  uuid               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationUuid    String               @map("integration_uuid") @db.Uuid
  externalCalendarId String               @map("external_calendar_id")
  summary            String?
  syncToken          String?              @map("sync_token")
  lastSyncedAt       DateTime?            @map("last_synced_at") @db.Timestamptz(6)
  webhookChannelId   String?              @unique @map("webhook_channel_id")
  webhookResourceId  String?              @map("webhook_resource_id")
  webhookExpiresAt   DateTime?            @map("webhook_expires_at") @db.Timestamptz(6)
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  integration        CalendarIntegrations @relation(fields: [integrationUuid], references: [uuid], onDelete: Cascade)
  taskLinks          TaskExternalLinks[]

  @@unique([integrationUuid, externalCalendarId])
  @@index([integrationUuid], map: "idx_synced_calendars_integration")
  @@map("calendar_synced_calendars")
}

model TaskExternalLinks {
  taskUuid           String                  @id @map("task_uuid") @db.Uuid
  syncedCalendarUuid String                  @map("synced_calendar_uuid") @db.Uuid
  externalEventId    String                  @map("external_event_id")
  externalEtag       String?                 @map("external_etag")
  lastSyncedAt       DateTime                @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  task               Tasks                   @relation(fields: [taskUuid], references: [uuid], onDelete: Cascade)
  syncedCalendar     CalendarSyncedCalendars @relation(fields: [syncedCalendarUuid], references: [uuid], onDelete: Cascade)

  @@unique([syncedCalendarUuid, externalEventId])
  @@index([syncedCalendarUuid], map: "idx_task_external_links_calendar")
  @@map("task_external_links")
}

model Devices {
  uuid         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid     String   @map("user_uuid") @db.Uuid
  pushToken    String   @unique @map("push_token")
  deviceName   String?  @map("device_name")
  deviceModel  String?  @map("device_model")
  appVersion   String?  @map("app_version")
  osVersion    String?  @map("os_version")
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         Users    @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid], map: "idx_devices_user")
  @@map("devices")
}

enum CalendarProvider {
  google
}

model OAuthIdentities {
  uuid           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid       String        @map("user_uuid") @db.Uuid
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt     DateTime      @default(now()) @map("last_used_at") @db.Timestamptz(6)
  user           Users         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userUuid, provider])
  @@index([userUuid], map: "idx_oauth_user")
  @@map("oauth_identities")
}

enum Language {
  ko
  en
}

enum OAuthProvider {
  google
  apple
}

enum AccentColorKey {
  red
  orange
  yellow
  green
  blue
  violet
  gray
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskBacklogKind {
  inbox
  folder
}

enum TaskActiveKind {
  todo
  big3
}

enum TaskTimeboxKind {
  timeline
}

enum TaskAffiliation {
  google
}

model Canvases {
  uuid              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid          String              @map("user_uuid") @db.Uuid
  date              DateTime            @db.Date
  storageKey        String              @map("storage_key")
  version           String              @default("v1.init")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              Users               @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  taskCanvasSources TaskCanvasSources[]

  @@unique([userUuid, date])
  @@map("canvases")
}

model TaskCanvasSources {
  taskUuid   String    @id @map("task_uuid") @db.Uuid
  canvasUuid String?   @map("canvas_uuid") @db.Uuid
  sourceKey  String    @unique @map("source_key")
  ocrText    String?   @map("ocr_text")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  task       Tasks     @relation(fields: [taskUuid], references: [uuid], onDelete: Cascade)
  canvas     Canvases? @relation(fields: [canvasUuid], references: [uuid], onDelete: SetNull)

  @@map("task_canvas_sources")
}

enum RoutineRepeatKind {
  day_of_week
  week
  day
}

enum TermsKind {
  service
  privacy
  marketing
}

model Terms {
  uuid        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind        TermsKind
  version     Int
  isRequired  Boolean           @map("is_required")
  effectiveAt DateTime          @map("effective_at") @db.Timestamptz(6)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  contents    TermsContents[]
  agreements  TermsAgreements[]

  @@unique([kind, version])
  @@index([kind, version(sort: Desc)], map: "idx_terms_kind_version")
  @@map("terms")
}

model TermsContents {
  termsUuid String   @map("terms_uuid") @db.Uuid
  language  Language
  content   String
  terms     Terms    @relation(fields: [termsUuid], references: [uuid], onDelete: Cascade)

  @@id([termsUuid, language])
  @@map("terms_contents")
}

model TermsAgreements {
  uuid      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid  String   @map("user_uuid") @db.Uuid
  termsUuid String   @map("terms_uuid") @db.Uuid
  agreed    Boolean
  agreedAt  DateTime @default(now()) @map("agreed_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent")
  user      Users    @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  terms     Terms    @relation(fields: [termsUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid], map: "idx_terms_agreements_user")
  @@index([termsUuid], map: "idx_terms_agreements_terms")
  @@index([userUuid, agreedAt(sort: Desc)], map: "idx_terms_agreements_user_agreed_at")
  @@map("terms_agreements")
}

/// lineageUuid: 같은 논리적 routine의 시간순 버전 그룹 ID.
/// 신규 routine은 DB가 gen_random_uuid()로 자체 발급, "수정" 의도의 후속 버전은 client가 이전 routine의 lineageUuid를 전달.
/// soft delete: deletedAt이 NULL이 아니면 client가 occurrence 시각과 비교해 렌더링 여부를 판단한다. 서버는 deleted 여부와 무관하게 항상 반환.
model Routines {
  uuid           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid       String            @map("user_uuid") @db.Uuid
  lineageUuid    String            @default(dbgenerated("gen_random_uuid()")) @map("lineage_uuid") @db.Uuid
  title          String
  repeatKind     RoutineRepeatKind @map("repeat_kind")
  repeatWeekdays Int[]             @map("repeat_weekdays") @db.SmallInt
  repeatInterval Int?              @map("repeat_interval")
  anchorDate     DateTime          @map("anchor_date") @db.Date
  startTime      DateTime          @map("start_time") @db.Time(6)
  durationSec    Int               @map("duration_sec")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)
  user           Users             @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid], map: "idx_routines_user")
  @@index([userUuid, lineageUuid], map: "idx_routines_user_lineage")
  @@map("routines")
}

enum FocusSessionKind {
  focus
  break
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum SubscriptionPlatform {
  ios
  android
  web
}

enum SubscriptionEventKind {
  trial_started
  trial_converted
  renewed
  canceled
  refunded
  expired
  reactivated
}

model Subscriptions {
  uuid                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid              String               @map("user_uuid") @db.Uuid
  status                SubscriptionStatus
  platform              SubscriptionPlatform
  trialStartAt          DateTime?            @map("trial_start_at") @db.Timestamptz(6)
  trialEndAt            DateTime?            @map("trial_end_at") @db.Timestamptz(6)
  currentPeriodStart    DateTime?            @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd      DateTime?            @map("current_period_end") @db.Timestamptz(6)
  externalProductId     String?              @map("external_product_id")
  externalTransactionId String?              @map("external_transaction_id")
  canceledAt            DateTime?            @map("canceled_at") @db.Timestamptz(6)
  cancelReason          String?              @map("cancel_reason")
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  Users                @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  events                SubscriptionEvents[]

  @@index([userUuid], map: "idx_subscriptions_user")
  @@map("subscriptions")
}

model SubscriptionEvents {
  uuid             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionUuid String                @map("subscription_uuid") @db.Uuid
  userUuid         String                @map("user_uuid") @db.Uuid
  kind             SubscriptionEventKind
  occurredAt       DateTime              @map("occurred_at") @db.Timestamptz(6)
  metadata         Json?                 @db.JsonB
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  subscription     Subscriptions         @relation(fields: [subscriptionUuid], references: [uuid], onDelete: Cascade)
  user             Users                 @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([subscriptionUuid], map: "idx_sub_events_subscription")
  @@index([userUuid, kind], map: "idx_sub_events_user_kind")
  @@map("subscription_events")
}

model FocusSessions {
  uuid      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid  String           @map("user_uuid") @db.Uuid
  kind      FocusSessionKind
  taskUuid  String?          @map("task_uuid") @db.Uuid
  startedAt DateTime         @map("started_at") @db.Timestamptz(6)
  endedAt   DateTime?        @map("ended_at") @db.Timestamptz(6)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  user      Users            @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  task      Tasks?           @relation(fields: [taskUuid], references: [uuid], onDelete: SetNull)

  @@index([userUuid, startedAt(sort: Desc)], map: "idx_focus_sessions_user_started")
  @@map("focus_sessions")
}

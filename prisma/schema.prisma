generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Users {
  uuid            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String?
  displayName     String?           @map("display_name")
  language        Language
  timezone        String
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  oauthIdentities OAuthIdentities[]

  @@map("users")
}

model OAuthIdentities {
  uuid           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userUuid       String        @map("user_uuid") @db.Uuid
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt     DateTime      @default(now()) @map("last_used_at") @db.Timestamptz(6)
  user           Users         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userUuid, provider])
  @@index([userUuid], map: "idx_oauth_user")
  @@map("oauth_identities")
}

enum Language {
  ko
  en
}

enum OAuthProvider {
  google
  apple
}
